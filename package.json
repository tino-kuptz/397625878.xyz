{
  "name": "397625878-xyz",
  "version": "1.0.0",
  "description": "Cloudflare Worker for logging requests to all subdomains under 397625878.xyz",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy -e production",
    "db:create": "npx wrangler d1 create tools-kup-tz",
    "db:migrate:dev": "npx wrangler d1 execute tools-kup-tz --local --file=./schema.sql",
    "db:migrate:prod": "npx wrangler d1 execute tools-kup-tz --file=./schema.sql",
    "db:list": "npx wrangler d1 execute tools-kup-tz --local --command=\"SELECT * FROM http_request_logs ORDER BY timestamp DESC LIMIT 10\""
  },
  "devDependencies": {
    "wrangler": "^4.31.0"
  },
  "keywords": [
    "cloudflare",
    "worker",
    "d1",
    "request-logging"
  ],
  "author": "Tino Kuptz <tino@kup.tz>",
  "repository": {
    "type": "git",
    "url": "https://github.com/tino-kuptz/397625878.xyz"
  },
  "license": "MIT"
}
